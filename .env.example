# Scraper behaviour
HEADLESS=true
REQUEST_DELAY_SECONDS=2.5
MAX_RETRIES=3

# Cache
CACHE_ENABLED=true
CACHE_DIR=.cache

# Playwright browser (chromium, firefox, webkit)
PLAYWRIGHT_BROWSER=chromium

# Optional HTTP proxy (leave blank to disable)
HTTP_PROXY=

# Salesforce — client credentials OAuth flow
# Leave all four blank to disable Salesforce sync entirely.
# SF_TOKEN_URL  : OAuth2 token endpoint
#                 e.g. https://login.salesforce.com/services/oauth2/token
#                      https://test.salesforce.com/services/oauth2/token  (sandbox)
# SF_API_ENDPOINT : REST endpoint for the target Salesforce object
#                   e.g. https://myorg.my.salesforce.com/services/data/v57.0/sobjects/ProductSync__c/
SF_TOKEN_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=
